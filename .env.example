# ── Database (Neon Postgres) ──────────────────────────────────────────────────
# Get from: console.neon.tech → your project → Connection Details
DATABASE_URL=postgresql://user:password@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://user:password@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# ── Admin API ─────────────────────────────────────────────────────────────────
# Random secret — generate with: openssl rand -hex 32
ADMIN_API_KEY=your-secret-here

# Public admin key (only needed for browser-based admin UI)
# NEXT_PUBLIC_ADMIN_API_KEY=your-secret-here

# ── Content mode ──────────────────────────────────────────────────────────────
# Set USE_DB=false to force file-based mode even when DATABASE_URL is set
# USE_DB=false

# ── Discovery sources ─────────────────────────────────────────────────────────
NEWSAPI_KEY=your-newsapi-key
TWITTER_BEARER_TOKEN=your-twitter-bearer-token

# Toggle individual sources
GDELT_ENABLED=true
RSS_ENABLED=true
NEWSAPI_ENABLED=true
TWITTER_ENABLED=true

# ── Site ──────────────────────────────────────────────────────────────────────
SITE_URL=https://tsgov.in
