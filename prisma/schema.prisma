generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ─── Published content ──────────────────────────────────────────────────────

model Promise {
  id                   String          @id @default(cuid())
  slug                 String          @unique
  title                String
  category             String
  manifesto_section    String
  announced_date       String
  deadline             String?
  deadline_date        String?
  target_beneficiaries String?
  target_amount        String?
  ministry             String?
  responsible_minister String?
  election_cycle       String?
  districts            String[]
  budget_allocated     String?
  budget_spent         String?
  current_status       String
  evidence_grade       String
  summary              String          @db.Text
  tags                 String[]
  last_reviewed        String
  reviewer_notes       String?
  discovery_id         String?
  created_at           DateTime        @default(now())
  updated_at           DateTime        @updatedAt

  sources     PromiseSource[]
  updates     PromiseUpdate[]
  fact_checks PromiseFactCheck[]
}

model PromiseSource {
  id           String  @id @default(cuid())
  promise_id   String
  label        String
  url          String
  date         String
  outlet       String
  source_type  String
  archived_url String?
  handle       String?
  promise      Promise @relation(fields: [promise_id], references: [id], onDelete: Cascade)
}

model PromiseUpdate {
  id         String               @id @default(cuid())
  promise_id String
  date       String
  note       String               @db.Text
  promise    Promise              @relation(fields: [promise_id], references: [id], onDelete: Cascade)
  sources    PromiseUpdateSource[]
}

model PromiseUpdateSource {
  id          String        @id @default(cuid())
  update_id   String
  label       String
  url         String
  date        String
  outlet      String
  source_type String
  update      PromiseUpdate @relation(fields: [update_id], references: [id], onDelete: Cascade)
}

model PromiseFactCheck {
  id         String  @id @default(cuid())
  promise_id String
  outlet     String
  url        String
  verdict    String
  date       String
  promise    Promise @relation(fields: [promise_id], references: [id], onDelete: Cascade)
}

model Incident {
  id                   String           @id @default(cuid())
  slug                 String           @unique
  title                String
  date                 String
  category             String
  district             String
  people_involved      String[]
  evidence_grade       String
  body                 String           @db.Text
  tags                 String[]
  related_promises     String[]
  last_reviewed        String
  discovery_id         String?
  affected_demographic String?
  created_at           DateTime         @default(now())
  updated_at           DateTime         @updatedAt

  sources IncidentSource[]
}

model IncidentSource {
  id           String   @id @default(cuid())
  incident_id  String
  label        String
  url          String
  date         String
  outlet       String
  source_type  String
  archived_url String?
  handle       String?
  incident     Incident @relation(fields: [incident_id], references: [id], onDelete: Cascade)
}

// ─── Politicians & accountability ───────────────────────────────────────────

model Politician {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  party           String
  constituency    String?
  position        String
  ministry        String?
  district        String?
  age             Int?
  education       String?
  profession      String?
  photo_url       String?
  myneta_url      String?
  wikipedia_url   String?
  bio             String?  @db.Text
  election_cycle  String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  criminal_cases     CriminalCase[]
  asset_declarations AssetDeclaration[]
}

model CriminalCase {
  id            String     @id @default(cuid())
  politician_id String
  case_type     String
  ipc_sections  String[]
  court         String?
  case_number   String?
  status        String
  date_filed    String?
  summary       String     @db.Text
  source_url    String?
  is_serious    Boolean    @default(false)
  politician    Politician @relation(fields: [politician_id], references: [id], onDelete: Cascade)
}

model AssetDeclaration {
  id               String     @id @default(cuid())
  politician_id    String
  year             String
  election_type    String?
  total_assets_inr Float?
  liabilities_inr  Float?
  movable_inr      Float?
  immovable_inr    Float?
  source_url       String?
  politician       Politician @relation(fields: [politician_id], references: [id], onDelete: Cascade)

  @@unique([politician_id, year])
}

model CrimeStatistic {
  id         String   @id @default(cuid())
  year       String
  district   String
  category   String
  count      Int
  source     String
  source_url String?
  notes      String?
  created_at DateTime @default(now())
}

// ─── Discovery pipeline ─────────────────────────────────────────────────────

model Discovery {
  id                       String    @id @default(cuid())
  title                    String
  body_text                String?   @db.Text
  url                      String    @unique
  outlet                   String?
  source_type              String?
  date                     String?
  discovery_source         String    // "rss" | "gdelt" | "newsapi" | "twitter_official" | "twitter_keyword"
  suggested_category       String?
  suggested_evidence_grade String?
  suggested_type           String?   // "promise" | "incident" | "unknown"
  status                   String    @default("pending_review")
  reviewed_by              String?
  rejection_reason         String?
  reviewed_at              DateTime?
  archived_url             String?
  created_at               DateTime  @default(now())
}
